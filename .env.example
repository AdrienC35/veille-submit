# ─── PostgreSQL (standard PG* vars) ───
PGHOST=localhost
PGPORT=5432
PGDATABASE=main
PGUSER=admin
PGPASSWORD=changeme

# ─── App ───
PORT=7890
APP_NAME=Veille Submit
DB_SCHEMA=veille
DB_TABLE=feed_items
AGENT_ID=1

# ─── ntfy — Receive URLs (optional) ───
# Subscribe to a ntfy topic to receive URLs via push
NTFY_SERVER=https://ntfy.sh
NTFY_SUBSCRIBE_TOPIC=my-veille-submit
NTFY_AUTH_USER=
NTFY_AUTH_PASS=

# ─── ntfy — Send notifications (optional) ───
# Get push notifications when a URL is added
NTFY_NOTIFY_TOPIC=my-veille-notifications
NTFY_NOTIFY_SERVER=https://ntfy.sh
